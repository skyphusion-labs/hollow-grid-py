# Copy to .env and fill in for federation. Leave GRID_* unset for standalone play.

WORLD_NAME=Verdigris Spool
# Public WebSocket URL advertised to the Grid registry (travel handoff).
WORLD_URL=wss://verdigris.skyphusion.org/ws

# Grid Hub HTTP RPC (deploy the-hollow-grid grid-hub first).
GRID_HUB_URL=https://grid-hub.skyphusion.org/rpc
GRID_HUB_TOKEN=

# Optional overrides (defaults match local dev)
# LISTEN_HOST=127.0.0.1
# LISTEN_PORT=8791
# DATA_DIR=data
# ADMINS=skyphusion
